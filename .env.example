# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=printerdb
POSTGRES_USER=printer
POSTGRES_PASSWORD=changeme_5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Backend API ---
SECRET_KEY=change-me-to-64-char-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
API_PORT=8000

# --- Monitoring Service ---
MONITORING_PORT=9000
MONITORING_INTERVAL_SECONDS=300
SNMP_COMMUNITY=public
SNMP_RETRIES=2
SNMP_TIMEOUT=3

# --- Discovery Service ---
DISCOVERY_PORT=9001
DISCOVERY_SUBNETS=192.168.0.0/24,10.0.0.0/24
